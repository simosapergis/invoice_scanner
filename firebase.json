{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": [
      "npm --prefix functions run lint",
      "npm --prefix functions run test"
    ],
    "ignore": [
      "node_modules",
      ".git",
      "*.log"
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 5002
    },
    "storage": {
      "port": 5003
    },
    "ui": {
      "enabled": true,
      "port": 5004
    },
    "singleProjectMode": true
  },
  "firestore": {
    "database": "(default)",
    "location": "europe-west3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
